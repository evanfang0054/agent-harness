# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123
DB_DATABASE=fruit_shop
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_DB=0  # 可选：选择 Redis 数据库编号（测试环境用 1 做隔离）

# JWT
JWT_SECRET=your-jwt-secret-change-in-prod
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# Server
PORT=3000

# Logging
LOG_LEVEL=info

# Swagger（设为 false 关闭 API 文档）
SWAGGER_ENABLED=true
